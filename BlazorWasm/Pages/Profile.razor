@page "/profile"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject JwtAuthenticationStateProvider AuthProvider
@inject OrderApiService OrderService
@inject WishlistService WishlistService
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>My Account - Avrang.tj</PageTitle>

<div class="dashboard-grid fade-in-up">
    <aside class="sidebar-nav">
        <a href="/profile" class="sidebar-link active">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
        </a>
        <a href="/orders" class="sidebar-link">
            <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            Order History
        </a>
        <a href="/favorites" class="sidebar-link">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            Saved Favorites
        </a>
        <a href="javascript:void(0)" class="sidebar-link">
            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            Recently Viewed
        </a>
        <div style="margin-top: auto; padding-top: var(--space-4); border-top: 1px solid var(--border-light);">
            <button class="sidebar-link" @onclick="Logout" style="color: #999; border:none; background:none; width:100%; text-align:left; cursor:pointer; font:inherit;">
                <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Logout
            </button>
        </div>
    </aside>

    <div class="dashboard-content stagger-stair">
        <div class="dashboard-header">
            <h1 class="bounce-in">Welcome back, @_userName</h1>
            <p class="text-muted">Manage your orders, favorites, and account details here.</p>
        </div>

        <div class="section-card hover-lift">
            <div class="section-title">
                <h2>Recent Orders</h2>
                <a href="/orders" class="view-all">View History</a>
            </div>
            @if (_isLoadingOrders)
            {
                <div style="text-align:center; padding: 20px;"><div class="loading-spinner"></div></div>
            }
            else if (!_recentOrders.Any())
            {
                <p class="text-muted" style="padding: 20px;">You haven't placed any orders yet.</p>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in _recentOrders.Take(3))
                    {
                        <div class="order-row interactive-row">
                            <span style="font-weight: 500;">#ORD-@order.Id.ToString("D5")</span>
                            <span class="text-muted">@order.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <span>$@order.TotalAmount.ToString("F2")</span>
                            <div><span class="status-pill status-@order.Status.ToLower()">@order.Status</span></div>
                            <a href="/orders" class="view-all outline-hover">Details</a>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="section-card hover-lift delay-1">
            <div class="section-title">
                <h2>Saved Favorites</h2>
                <a href="/favorites" class="view-all">Manage List</a>
            </div>
            @if (!WishlistService.Items.Any())
            {
                <p class="text-muted" style="padding: 20px;">Your wishlist is empty.</p>
            }
            else
            {
                <div class="horizontal-scroll">
                    @foreach (var prod in WishlistService.Items.Take(5))
                    {
                        <div class="mini-card hover-zoom" @onclick='() => Nav.NavigateTo($"/product/{prod.Id}")' style="cursor:pointer;">
                            <div class="mini-image">
                                <img src="@GetProductImage(prod)" alt="@prod.Name" style="width:100%; height:100%; object-fit:cover; border-radius: var(--radius-sm);" />
                            </div>
                            <div class="mini-info">
                                <h4>@prod.Name</h4>
                                <span class="mini-price price-accent">$@prod.Price.ToString("F2")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _userName = "User";
    private List<OrderModel> _recentOrders = new();
    private bool _isLoadingOrders = true;

    protected override async Task OnInitializedAsync()
    {
        _userName = await AuthProvider.GetUserNameAsync() ?? "User";
        _recentOrders = await OrderService.GetMyOrdersAsync();
        _isLoadingOrders = false;
        
        await WishlistService.InitializeAsync();
        WishlistService.OnChanged += StateHasChanged;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/");
    }

    private static readonly Dictionary<string, string> _imageMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["iphone"] = "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400&q=80",
        ["samsung"] = "https://images.unsplash.com/photo-1610945415295-d9bbf067e59c?w=400&q=80",
        ["macbook"] = "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=400&q=80",
        ["ipad"] = "https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?w=400&q=80",
    };

    private static readonly string[] _fallbackImages = {
        "https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=400&q=80",
        "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=400&q=80",
    };

    private string GetProductImage(Product p)
    {
        if (!string.IsNullOrEmpty(p.ImageUrl)) return p.ImageUrl;
        var name = p.Name.ToLower();
        foreach (var kv in _imageMap)
            if (name.Contains(kv.Key)) return kv.Value;
        return _fallbackImages[Math.Abs(p.Id) % _fallbackImages.Length];
    }

    public void Dispose()
    {
        WishlistService.OnChanged -= StateHasChanged;
    }
}
