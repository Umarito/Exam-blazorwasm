            Settings
        </a>
        <div style="margin-top: auto; padding-top: var(--space-4); border-top: 1px solid var(--border-light);">
            <a href="#" class="sidebar-link" style="color: #999;">
                <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Logout
            </a>
        </div>
    </aside>

    <div class="dashboard-content stagger-stair">
        <div class="dashboard-header">
            <h1 class="bounce-in">Welcome back, Alex</h1>
            <p class="text-muted">Manage your orders, favorites, and account details here.</p>
        </div>

        <div class="section-card hover-lift">
            <div class="section-title">
                <h2>Recent Orders</h2>
                <a href="#" class="view-all">View History</a>
            </div>
            <div class="order-list">
                <div class="order-row interactive-row">
                    <span style="font-weight: 500;">#ORD-55291</span>
                    <span class="text-muted">Oct 24, 2023</span>
                    <span>$1,249.00</span>
                    <div><span class="status-pill status-delivered">Delivered</span></div>
                    <a href="#" class="view-all outline-hover">Details</a>
                </div>
                <div class="order-row interactive-row">
                    <span style="font-weight: 500;">#ORD-55104</span>
                    <span class="text-muted">Oct 18, 2023</span>
                    <span>$89.00</span>
                    <div><span class="status-pill status-processing">Processing</span></div>
                    <a href="#" class="view-all outline-hover">Details</a>
                </div>
            </div>
        </div>

        <div class="section-card hover-lift delay-1">
            <div class="section-title">
                <h2>Saved Favorites</h2>
                <a href="/favorites" class="view-all">Manage List</a>
            </div>
            <div class="horizontal-scroll">
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner"></div></div>
                    <div class="mini-info">
                        <h4>Pro Sound Studio Pods</h4>
                        <span class="mini-price">$349.00</span>
                    </div>
                </div>
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner"></div></div>
                    <div class="mini-info">
                        <h4>UltraThin Laptop 14"</h4>
                        <span class="mini-price">$999.00</span>
                    </div>
                </div>
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner"></div></div>
                    <div class="mini-info">
                        <h4>Smart Home Hub V2</h4>
                        <span class="mini-price">$129.00</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-card hover-lift delay-2">
            <div class="section-title">
                <h2>Recently Viewed</h2>
            </div>
            <div class="horizontal-scroll">
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner" style="opacity: 0.6;"></div></div>
                    <div class="mini-info">
                        <h4>Mechanical Keyboard</h4>
                        <span class="mini-price">$159.00</span>
                    </div>
                </div>
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner" style="opacity: 0.6;"></div></div>
                    <div class="mini-info">
                        <h4>4K OLED Monitor</h4>
                        <span class="mini-price">$799.00</span>
                    </div>
                </div>
                <div class="mini-card hover-zoom">
                    <div class="mini-image"><div class="mini-image-inner" style="opacity: 0.6;"></div></div>
                    <div class="mini-info">
                        <h4>Wireless Mouse Pro</h4>
                        <span class="mini-price">$79.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
