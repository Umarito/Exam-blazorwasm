@page "/checkout"
@inject FakeDataService DataService

<PageTitle>Checkout - Avrang.tj</PageTitle>

<div class="checkout-steps">
    <div class="step">
        <div class="step-number">✓</div>
        <span>Cart</span>
    </div>
    <div class="step-line"></div>
    <div class="step active">
        <div class="step-number">2</div>
        <span>Details</span>
    </div>
    <div class="step-line"></div>
    <div class="step">
        <div class="step-number">3</div>
        <span>Payment</span>
    </div>
</div>

<div class="checkout-layout">
    <div class="checkout-main">
        
        <section class="checkout-section">
            <h2 class="section-title">Shipping Address</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" placeholder="John" @bind="ShippingDetails.FirstName">
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" placeholder="Doe" @bind="ShippingDetails.LastName">
                </div>
                <div class="form-group full">
                    <label>Street Address</label>
                    <input type="text" placeholder="123 Modern St, Apt 4" @bind="ShippingDetails.Address">
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input type="text" placeholder="Dushanbe" @bind="ShippingDetails.City">
                </div>
                <div class="form-group">
                    <label>Postal Code</label>
                    <input type="text" placeholder="734000" @bind="ShippingDetails.Zip">
                </div>
                <div class="form-group full">
                    <label>Phone Number</label>
                    <input type="tel" placeholder="+992 00 000 0000" @bind="ShippingDetails.Phone">
                </div>
            </div>
        </section>

        <section class="checkout-section">
            <h2 class="section-title">Payment Method</h2>
            <div class="payment-options">
                <div class="payment-card @(PaymentMethod == "Card" ? "selected" : "")" @onclick="@(() => PaymentMethod = "Card")">
                    <div class="radio-circle"></div>
                    <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
                    <div>
                        <div style="font-weight: 500;">Credit or Debit Card</div>
                        <div class="text-small">Visa, Mastercard, Amex</div>
                    </div>
                </div>
                <div class="payment-card @(PaymentMethod == "Cash" ? "selected" : "")" @onclick="@(() => PaymentMethod = "Cash")">
                    <div class="radio-circle"></div>
                    <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                    <div>
                        <div style="font-weight: 500;">Cash on Delivery</div>
                        <div class="text-small">Pay when you receive the package</div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <aside class="order-summary">
        <h3 style="margin-bottom: var(--space-4);">Order Summary</h3>
        
        @foreach(var item in CartItems)
        {
            <div class="cart-mini-item">
                <div class="mini-img"></div>
                <div class="mini-details">
                    <span class="mini-name">@item.Product.Name</span>
                    <span class="mini-price">@item.Quantity × $@item.Product.Price.ToString("F2")</span>
                </div>
            </div>
        }

        <div style="margin-top: var(--space-5);">
            <div class="summary-item">
                <span>Subtotal</span>
                <span>$@Subtotal.ToString("F2")</span>
            </div>
            <div class="summary-item">
                <span>Shipping</span>
                <span>Free</span>
            </div>
            <div class="summary-item">
                <span>Tax (8%)</span>
                <span>$@Tax.ToString("F2")</span>
            </div>
            <div class="summary-total">
                <span>Total</span>
                <span>$@Total.ToString("F2")</span>
            </div>
        </div>

        <button class="btn btn-primary" @onclick="CompletePurchase">Complete Purchase</button>
        <p class="text-small" style="text-align: center; margin-top: var(--space-3);">
            Secure 256-bit SSL encrypted payment
        </p>
    </aside>
</div>

@if (ShowSuccess)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;">
        <div style="background: white; padding: 40px; border-radius: 16px; text-align: center; max-width: 400px;">
            <div style="width: 60px; height: 60px; background: #27ae60; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <svg viewBox="0 0 24 24" style="width: 30px; height: 30px; stroke-width: 3;"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <h2 style="margin-bottom: 10px;">Order Confirmed!</h2>
            <p style="color: var(--text-secondary); margin-bottom: 24px;">Thank you for your purchase. We'll email you an order confirmation with details and tracking info.</p>
            <a href="/" class="btn btn-primary" style="width: 100%;">Return to Home</a>
        </div>
    </div>
}

@code {
    private List<CartItem> CartItems { get; set; } = new();
    private string PaymentMethod { get; set; } = "Card";
    private bool ShowSuccess { get; set; } = false;

    private class ShippingInfo 
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Address { get; set; } = "";
        public string City { get; set; } = "";
        public string Zip { get; set; } = "";
        public string Phone { get; set; } = "";
    }

    private ShippingInfo ShippingDetails { get; set; } = new();

    protected override void OnInitialized()
    {
        var products = DataService.Products.Take(2).ToList();
        if (products.Count >= 2)
        {
            CartItems.Add(new CartItem { Id = 1, Product = products[0], Quantity = 1 });
            CartItems.Add(new CartItem { Id = 2, Product = products[1], Quantity = 1 });
        }
    }

    private decimal Subtotal => CartItems.Sum(i => i.Product.Price * i.Quantity);
    private decimal Tax => Subtotal * 0.08m;
    private decimal Total => Subtotal + Tax;

    private void CompletePurchase()
    {
        ShowSuccess = true;
    }
}
