@page "/"
@inject FakeDataService DataService

<PageTitle>Avrang.tj - Modern E-Commerce</PageTitle>

<section class="section hero fade-in-up">
    <div class="hero-content">
        <h1 class="bounce-in delay-1">Smart living starts here.</h1>
        <p class="fade-in delay-2">Discover the latest premium electronics and home appliances with unparalleled design.</p>
        <button class="btn btn-primary hover-lift delay-3 fade-in">Shop Collection</button>
    </div>
    
    <div class="hero-image-placeholder grey-box hover-zoom bounce-in delay-2">
        <span class="placeholder-letter" style="font-size: 120px; color: white;">A</span>
    </div> 
</section>

@{
    var featured = DataService.Products.FirstOrDefault(p => p.IsFeatured);
}

@if (featured != null)
{
    <section class="section stagger-stair">
        <div class="featured-product hover-lift">
            <div class="featured-image grey-box">
                <span class="placeholder-letter" style="font-size: 80px; color: white;">@featured.Name.ElementAtOrDefault(0)</span>
            </div>
            <div class="featured-details">
                <span class="badge-tag">Product of the Week</span>
                <h2>@featured.Name</h2>
                <div class="rating">
                    <svg style="fill: currentColor; stroke: none; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <svg style="fill: currentColor; stroke: none; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <svg style="fill: currentColor; stroke: none; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <svg style="fill: currentColor; stroke: none; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <svg style="fill: none; stroke: currentColor; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <span>(@featured.ReviewCount reviews)</span>
                </div>
                <p class="text-muted">@featured.Description</p>
                <div class="price-block">
                    <span class="current">$@featured.Price.ToString("F2")</span>
                    @if (featured.OriginalPrice > featured.Price)
                    {
                        <span class="original">$@featured.OriginalPrice.ToString("F2")</span>
                    }
                </div>
                <div class="featured-actions">
                    <button class="btn btn-primary">Add to Cart</button>
                    <a href="/product/@featured.Id" class="btn btn-outline">View Details</a>
                </div>
            </div>
        </div>
    </section>
}

<section class="section" style="padding-top: 0;">
    <div class="trust-bar">
        <div class="trust-item">
            <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></div>
            <span class="trust-text">Regular Discounts</span>
        </div>
        <div class="trust-item">
            <div class="trust-icon"><svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg></div>
            <span class="trust-text">Fast Delivery</span>
        </div>
        <div class="trust-item">
            <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
            <span class="trust-text">Secure Payments</span>
        </div>
        <div class="trust-item">
            <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></div>
            <span class="trust-text">24/7 Support</span>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-header">
        <h2>Trending Products</h2>
        <a href="#" class="btn btn-outline btn-sm" style="border-radius: var(--radius-pill);">View All</a>
    </div>
    
    <div class="product-grid stagger-stair">
        @foreach (var prod in DataService.Products.Where(p => p.IsTrending).Take(4))
        {
            <div class="product-card hover-lift fade-in-up">
                <a href="/product/@prod.Id" class="card-image-wrapper grey-box">
                    <span class="placeholder-letter">@prod.Name.ElementAtOrDefault(0)</span>
                </a>
                <div class="card-info">
                    <span class="text-small">@prod.Category?.Name</span>
                    <a href="/product/@prod.Id"><h3 class="card-title">@prod.Name</h3></a>
                    <div class="rating">
                        <svg style="fill: currentColor; stroke: none; width: 12px; height: 12px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <span>@prod.AverageRating</span>
                    </div>
                    <div class="card-bottom">
                        <span class="card-price price-accent">$@prod.Price.ToString("F2")</span>
                        <button class="btn-add hover-lift">
                            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
