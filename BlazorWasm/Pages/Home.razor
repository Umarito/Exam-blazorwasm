@page "/"
@inject ProductApiService ProductService
@inject CartStateService CartState
@inject WishlistService WishlistService
@inject CompareStateService CompareState

<PageTitle>Avrang.tj - Premium Electronics & Home Appliances</PageTitle>

<section class="section hero fade-in-up">
    <div class="hero-content">
        <h1 class="bounce-in delay-1">Smart living starts here.</h1>
        <p class="fade-in delay-2">Discover the latest premium electronics and home appliances with unparalleled design.</p>
        <a href="/categories" class="btn btn-primary hover-lift delay-3 fade-in">Shop Collection</a>
    </div>
    <div class="hero-image-placeholder hover-zoom bounce-in delay-2" style="background: linear-gradient(135deg,#1a1a2e,#16213e,#0f3460); border-radius: var(--radius-lg); display:flex; align-items:center; justify-content:center; overflow:hidden;">
        <img src="https://images.unsplash.com/photo-1498049794561-7780e7231661?w=600&q=80" alt="Hero products" style="width:100%; height:100%; object-fit:cover;" />
    </div>
</section>

@if (_isLoading)
{
    <div class="section" style="text-align:center; padding: 60px 0;">
        <div class="loading-spinner"></div>
        <p class="text-muted" style="margin-top:16px;">Loading products...</p>
    </div>
}
else
{
    @if (FeaturedProduct != null)
    {
        <section class="section stagger-stair">
            <div class="featured-product hover-lift">
                <div class="featured-image">
                    <img src="@GetProductImage(FeaturedProduct)" alt="@FeaturedProduct.Name" style="width:100%; height:100%; object-fit:cover; border-radius: var(--radius-lg);" />
                </div>
                <div class="featured-details">
                    <span class="badge-tag">Product of the Week</span>
                    <h2>@FeaturedProduct.Name</h2>
                    <div class="rating">
                        @for (int i = 0; i < 5; i++)
                        {
                            var filled = i < (int)Math.Round(FeaturedProduct.AverageRating);
                            <svg style="fill: @(filled ? "currentColor" : "none"); stroke: currentColor; width: 16px; height: 16px;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        }
                        <span>(@FeaturedProduct.ReviewCount reviews)</span>
                    </div>
                    <p class="description">@FeaturedProduct.Description</p>
                    <div class="price-row">
                        <span class="price-accent h2">$@FeaturedProduct.Price.ToString("F2")</span>
                    </div>
                    <div class="actions">
                        <button class="btn btn-primary btn-sm hover-lift" @onclick="() => CartState.AddToCart(FeaturedProduct)">Add to Cart</button>
                        <button class="btn btn-outline btn-sm hover-lift" @onclick="() => ToggleWishlist(FeaturedProduct)">
                            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    }

    <section class="section">
        <div class="trust-indicators fade-in">
            <div class="trust-item">
                <div class="trust-icon"><svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg></div>
                <span class="trust-text">Fast Delivery</span>
            </div>
            <div class="trust-item">
                <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                <span class="trust-text">Secure Payments</span>
            </div>
            <div class="trust-item">
                <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></div>
                <span class="trust-text">24/7 Support</span>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="section-header">
            <h2>Trending Products</h2>
            <a href="/categories" class="btn btn-outline btn-sm" style="border-radius: var(--radius-pill);">View All</a>
        </div>

        <div class="product-grid stagger-stair">
            @foreach (var prod in _products.Take(8))
            {
                <div class="product-card hover-lift fade-in-up">
                    <a href="/product/@prod.Id" class="card-image-wrapper">
                        <img src="@GetProductImage(prod)" alt="@prod.Name" style="width:100%; height:100%; object-fit:cover;" />
                    </a>
                    <div class="card-actions-overlay">
                        <button class="overlay-btn @(WishlistService.IsInWishlist(prod.Id) ? "active-wish" : "")"
                                title="@(WishlistService.IsInWishlist(prod.Id) ? "Remove from Wishlist" : "Add to Wishlist")"
                                @onclick="() => ToggleWishlist(prod)" @onclick:stopPropagation>
                            <svg viewBox="0 0 24 24" style="width:16px;height:16px;"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                        </button>
                        <button class="overlay-btn @(CompareState.IsInCompare(prod.Id) ? "active-compare" : "")"
                                title="@(CompareState.IsInCompare(prod.Id) ? "Remove from Compare" : "Add to Compare")"
                                @onclick="() => CompareState.Toggle(prod)" @onclick:stopPropagation>
                            <svg viewBox="0 0 24 24" style="width:16px;height:16px;"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                        </button>
                    </div>
                    <div class="card-info">
                        <span class="text-small">@prod.Category?.Name</span>
                        <a href="/product/@prod.Id"><h3 class="card-title">@prod.Name</h3></a>
                        <div class="card-bottom">
                            <span class="card-price price-accent">$@prod.Price.ToString("F2")</span>
                            <button class="btn-add hover-lift" @onclick="() => CartState.AddToCart(prod)" title="Add to Cart">
                                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    @if (_products.Count == 0)
    {
        <div style="text-align:center; padding: 60px 0;">
            <p class="text-muted">No products found. Please check back soon!</p>
        </div>
    }
}

@code {
    private List<Product> _products = new();
    private bool _isLoading = true;

    private Product? FeaturedProduct => _products.FirstOrDefault(p => p.IsFeatured);

    private static readonly Dictionary<string, string> _imageMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["iphone"] = "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400&q=80",
        ["samsung"] = "https://images.unsplash.com/photo-1610945415295-d9bbf067e59c?w=400&q=80",
        ["macbook"] = "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=400&q=80",
        ["ipad"] = "https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?w=400&q=80",
        ["headphone"] = "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&q=80",
        ["watch"] = "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&q=80",
        ["camera"] = "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=400&q=80",
        ["coffee"] = "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=400&q=80",
        ["earbuds"] = "https://images.unsplash.com/photo-1590658268037-6bf12165a8df?w=400&q=80",
        ["nike"] = "https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400&q=80",
        ["laptop"] = "https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=400&q=80",
        ["speaker"] = "https://images.unsplash.com/photo-1608043152269-423dbba4e7e1?w=400&q=80",
    };

    private static readonly string[] _fallbackImages = {
        "https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=400&q=80",
        "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=400&q=80",
        "https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?w=400&q=80",
        "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&q=80",
        "https://images.unsplash.com/photo-1484704849700-f032a568e944?w=400&q=80",
    };

    protected override async Task OnInitializedAsync()
    {
        _products = await ProductService.GetProductsAsync(1, 20);
        _isLoading = false;
    }

    private string GetProductImage(Product p)
    {
        if (!string.IsNullOrEmpty(p.ImageUrl)) return p.ImageUrl;
        var name = p.Name.ToLower();
        foreach (var kv in _imageMap)
            if (name.Contains(kv.Key)) return kv.Value;
        return _fallbackImages[Math.Abs(p.Id) % _fallbackImages.Length];
    }

    private async Task ToggleWishlist(Product p)
    {
        await WishlistService.ToggleAsync(p);
    }
}
