@page "/favorites"
@inject FakeDataService DataService

<PageTitle>Favorites - Avrang.tj</PageTitle>

@if (FavoriteProducts == null || !FavoriteProducts.Any())
{
    <div id="favorites-empty" class="fade-in">
        <div class="empty-state">
            <div class="empty-icon-box pulse">
                <svg style="width: 40px; height: 40px;" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </div>
            <h2>Your list is empty</h2>
            <p class="text-muted" style="max-width: 320px;">Save items you're interested in so you can easily find them later and even get notified of price drops.</p>
            <a href="/" class="btn btn-primary hover-lift">Start Shopping</a>
        </div>
    </div>
}
else
{
    <div id="favorites-filled" class="stagger-stair">
        <div class="page-header bounce-in">
            <div>
                <h1>Your Favorites</h1>
                <p class="text-muted">@FavoriteProducts.Count items saved to your wishlist</p>
            </div>
            <div style="display: flex; gap: var(--space-3);">
                <button class="btn btn-outline outline-hover">
                    <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                    Share List
                </button>
                <button class="btn btn-primary hover-lift">Add All to Cart</button>
            </div>
        </div>

        <div class="favorites-grid">
            @foreach (var prod in FavoriteProducts)
            {
                <div class="fav-card fade-in-up">
                    <div class="fav-image-wrapper fav-hover">
                        <button class="remove-btn" title="Remove from favorites" @onclick="() => RemoveFavorite(prod)">
                            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                        <div class="fav-image">
                            <!-- Image placed here -->
                        </div>
                    </div>
                    <div class="fav-info">
                        <span class="text-small">@prod.Category?.Name</span>
                        <h3 class="card-title">@prod.Name</h3>
                        <span class="fav-price @(prod.IsTrending ? "price-accent" : "")">$@prod.Price.ToString("F2")</span>
                    </div>
                    <div class="fav-actions">
                        <button class="btn btn-primary btn-sm hover-lift" style="flex:1;">Move to Cart</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Product> FavoriteProducts { get; set; } = new();

    protected override void OnInitialized()
    {
        // Mock favorites fetching 4 random products from FakeDataService
        FavoriteProducts = DataService.Products.Take(4).ToList();
    }

    private void RemoveFavorite(Product prod)
    {
        FavoriteProducts.Remove(prod);
    }
}
