@page "/contact-messages"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Contact Messages - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Contact Messages</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Message</button>
    </div>

    @if (_messages == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_messages.Count == 0)
    {
        <div class="alert alert-info">No messages found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Read</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _messages)
                {
                    <tr>
                        <td>@m.Id</td>
                        <td>@m.FullName</td>
                        <td>@m.Email</td>
                        <td>@m.Phone</td>
                        <td>@(m.IsRead ? "Yes" : "No")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditMessage(m)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMessage(m.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Message" : "Add Message")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingMessage" OnValidSubmit="SaveMessage">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>Full Name</label>
                            <InputText @bind-Value="_editingMessage.FullName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Email</label>
                            <InputText @bind-Value="_editingMessage.Email" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Phone</label>
                            <InputText @bind-Value="_editingMessage.Phone" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Message</label>
                            <InputTextArea @bind-Value="_editingMessage.Message" class="form-control" rows="4" />
                        </div>
                        <div class="form-check">
                            <InputCheckbox @bind-Value="_editingMessage.IsRead" class="form-check-input" id="msgRead" />
                            <label class="form-check-label" for="msgRead">Is Read</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<ContactMessage>? _messages;
    private bool _showModal;
    private bool _isEdit;
    private ContactMessage _editingMessage = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _messages = await Api.GetContactMessagesAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingMessage = new ContactMessage();
        _showModal = true;
    }

    private void EditMessage(ContactMessage m)
    {
        _isEdit = true;
        _editingMessage = new ContactMessage
        {
            Id = m.Id,
            FullName = m.FullName,
            Email = m.Email,
            Phone = m.Phone,
            Message = m.Message,
            IsRead = m.IsRead
        };
        _showModal = true;
    }

    private async Task SaveMessage()
    {
        bool success = _isEdit
            ? await Api.UpdateContactMessageAsync(_editingMessage)
            : await Api.CreateContactMessageAsync(_editingMessage);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteMessage(int id)
    {
        if (await Api.DeleteContactMessageAsync(id))
            await LoadData();
    }
}
