@page "/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Users - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Users</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add User</button>
    </div>

    @if (_users == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_users.Count == 0)
    {
        <div class="alert alert-info">No users found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in _users)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.FullName</td>
                        <td>@u.Email</td>
                        <td>@u.PhoneNumber</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditUser(u)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit User" : "Add User")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingUser" OnValidSubmit="SaveUser">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>Full Name</label>
                            <InputText @bind-Value="_editingUser.FullName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Email</label>
                            <InputText @bind-Value="_editingUser.Email" class="form-control" type="email" required />
                        </div>
                        <div class="mb-3">
                            <label>Phone</label>
                            <InputText @bind-Value="_editingUser.PhoneNumber" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Password</label>
                            <InputText @bind-Value="_editingUser.Password" class="form-control" type="password" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<User>? _users;
    private bool _showModal;
    private bool _isEdit;
    private User _editingUser = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _users = await Api.GetUsersAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingUser = new User();
        _showModal = true;
    }

    private void EditUser(User u)
    {
        _isEdit = true;
        _editingUser = new User
        {
            Id = u.Id,
            FullName = u.FullName,
            Email = u.Email,
            PhoneNumber = u.PhoneNumber,
            Password = u.Password
        };
        _showModal = true;
    }

    private async Task SaveUser()
    {
        bool success = _isEdit
            ? await Api.UpdateUserAsync(_editingUser)
            : await Api.CreateUserAsync(_editingUser);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteUser(int id)
    {
        if (await Api.DeleteUserAsync(id))
            await LoadData();
    }
}
