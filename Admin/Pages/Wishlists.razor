@page "/wishlists"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Wishlists - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Wishlists</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Wishlist</button>
    </div>

    @if (_items == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_items.Count == 0)
    {
        <div class="alert alert-info">No wishlists found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>UserId</th>
                    <th>ProductId</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in _items)
                {
                    <tr>
                        <td>@w.Id</td>
                        <td>@w.UserId</td>
                        <td>@w.ProductId</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditItem(w)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(w.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Wishlist" : "Add Wishlist")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingItem" OnValidSubmit="SaveItem">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>UserId</label>
                            <InputText @bind-Value="_editingItem.UserId" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>ProductId</label>
                            <InputNumber @bind-Value="_editingItem.ProductId" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Wishlist>? _items;
    private bool _showModal;
    private bool _isEdit;
    private Wishlist _editingItem = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _items = await Api.GetWishlistsAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingItem = new Wishlist();
        _showModal = true;
    }

    private void EditItem(Wishlist w)
    {
        _isEdit = true;
        _editingItem = new Wishlist
        {
            Id = w.Id,
            UserId = w.UserId,
            ProductId = w.ProductId
        };
        _showModal = true;
    }

    private async Task SaveItem()
    {
        bool success = _isEdit
            ? await Api.UpdateWishlistAsync(_editingItem)
            : await Api.CreateWishlistAsync(_editingItem);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteItem(int id)
    {
        if (await Api.DeleteWishlistAsync(id))
            await LoadData();
    }
}
