@page "/login"
@inject AuthService AuthService
@inject NavigationManager Nav
@inject JwtAuthenticationStateProvider AuthProvider

<PageTitle>Admin Login - Avrang.tj</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Avrang Admin</h2>
            <p class="text-muted">Sign in to manage the store</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <div class="form-group mb-3">
                <label>Email</label>
                <InputText @bind-Value="_model.Email" class="form-control" type="email" />
            </div>
            <div class="form-group mb-4">
                <label>Password</label>
                <InputText @bind-Value="_model.Password" class="form-control" type="password" />
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3" disabled="@_isLoading">
                @if (_isLoading) { <span class="spinner-border spinner-border-sm"></span> }
                else { <span>Login</span> }
            </button>
        </EditForm>

        <p class="text-center">
            Don't have an account? <a href="/register" class="text-decoration-none">Register here</a>
        </p>
    </div>
</div>

@code {
    private LoginDto _model = new();
    private string? _errorMessage;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;
        var (success, error) = await AuthService.LoginAsync(_model);
        if (success) Nav.NavigateTo("/");
        else _errorMessage = error;
        _isLoading = false;
    }
}
