@page "/categories"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Categories - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Categories</h1>
        <div class="d-flex gap-2">
            <input type="text" class="form-control" placeholder="New Category Name" @bind="_newCatName" />
            <button class="btn btn-success" @onclick="AddCategory">Add</button>
        </div>
    </div>

    @if (_categories == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else
    {
        <div class="row">
            @foreach (var cat in _categories)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <span>@cat.Name</span>
                            <span class="badge bg-secondary">ID: @cat.Id</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Category>? _categories;
    private string _newCatName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _categories = await Api.GetCategoriesAsync();
    }

    private async Task AddCategory()
    {
        if (string.IsNullOrWhiteSpace(_newCatName)) return;
        
        var success = await Api.CreateCategoryAsync(new Category { Name = _newCatName });
        if (success)
        {
            _newCatName = "";
            await LoadData();
        }
    }
}
