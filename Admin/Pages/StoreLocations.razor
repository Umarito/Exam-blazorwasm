@page "/store-locations"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Store Locations - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Store Locations</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Location</button>
    </div>

    @if (_locations == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_locations.Count == 0)
    {
        <div class="alert alert-info">No locations found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Address</th>
                    <th>Working Hours</th>
                    <th>Map Coordinates</th>
                    <th>CityId</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in _locations)
                {
                    <tr>
                        <td>@l.Id</td>
                        <td>@l.Address</td>
                        <td>@l.WorkingHours</td>
                        <td>@l.MapCoordinates</td>
                        <td>@l.CityId</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditLocation(l)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocation(l.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Location" : "Add Location")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingLocation" OnValidSubmit="SaveLocation">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>Address</label>
                            <InputText @bind-Value="_editingLocation.Address" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Working Hours</label>
                            <InputText @bind-Value="_editingLocation.WorkingHours" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Map Coordinates</label>
                            <InputText @bind-Value="_editingLocation.MapCoordinates" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>CityId</label>
                            <InputNumber @bind-Value="_editingLocation.CityId" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<StoreLocation>? _locations;
    private bool _showModal;
    private bool _isEdit;
    private StoreLocation _editingLocation = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _locations = await Api.GetStoreLocationsAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingLocation = new StoreLocation();
        _showModal = true;
    }

    private void EditLocation(StoreLocation l)
    {
        _isEdit = true;
        _editingLocation = new StoreLocation
        {
            Id = l.Id,
            Address = l.Address,
            WorkingHours = l.WorkingHours,
            MapCoordinates = l.MapCoordinates,
            CityId = l.CityId
        };
        _showModal = true;
    }

    private async Task SaveLocation()
    {
        bool success = _isEdit
            ? await Api.UpdateStoreLocationAsync(_editingLocation)
            : await Api.CreateStoreLocationAsync(_editingLocation);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteLocation(int id)
    {
        if (await Api.DeleteStoreLocationAsync(id))
            await LoadData();
    }
}
