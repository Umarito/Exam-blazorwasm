@page "/carts"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Carts - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Carts</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Cart</button>
    </div>

    @if (_carts == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_carts.Count == 0)
    {
        <div class="alert alert-info">No carts found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>UserId</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _carts)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.UserId</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditCart(c)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCart(c.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Cart" : "Add Cart")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingCart" OnValidSubmit="SaveCart">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>UserId</label>
                            <InputText @bind-Value="_editingCart.UserId" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Cart>? _carts;
    private bool _showModal;
    private bool _isEdit;
    private Cart _editingCart = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _carts = await Api.GetCartsAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingCart = new Cart();
        _showModal = true;
    }

    private void EditCart(Cart c)
    {
        _isEdit = true;
        _editingCart = new Cart
        {
            Id = c.Id,
            UserId = c.UserId
        };
        _showModal = true;
    }

    private async Task SaveCart()
    {
        bool success = _isEdit
            ? await Api.UpdateCartAsync(_editingCart)
            : await Api.CreateCartAsync(_editingCart);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteCart(int id)
    {
        if (await Api.DeleteCartAsync(id))
            await LoadData();
    }
}
