@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Dashboard - Avrang Admin</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">Dashboard</h1>
            <p class="text-muted">Welcome to Avrang Admin Panel</p>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else
    {
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="card bg-light shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title text-muted">Products</h5>
                                <h2 class="fw-bold">@_productCount</h2>
                            </div>
                            <span class="badge bg-primary" style="font-size: 2rem; padding: 0.7rem;">📦</span>
                        </div>
                        <a href="/products" class="btn btn-sm btn-outline-primary mt-3">Manage</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card bg-light shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title text-muted">Categories</h5>
                                <h2 class="fw-bold">@_categoryCount</h2>
                            </div>
                            <span class="badge bg-info" style="font-size: 2rem; padding: 0.7rem;">📂</span>
                        </div>
                        <a href="/categories" class="btn btn-sm btn-outline-info mt-3">Manage</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card bg-light shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title text-muted">Brands</h5>
                                <h2 class="fw-bold">@_brandCount</h2>
                            </div>
                            <span class="badge bg-success" style="font-size: 2rem; padding: 0.7rem;">🏷️</span>
                        </div>
                        <a href="/brands" class="btn btn-sm btn-outline-success mt-3">Manage</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card bg-light shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title text-muted">Installments</h5>
                                <h2 class="fw-bold">@_installmentCount</h2>
                            </div>
                            <span class="badge bg-warning" style="font-size: 2rem; padding: 0.7rem;">💳</span>
                        </div>
                        <a href="/installments" class="btn btn-sm btn-outline-warning mt-3">Manage</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private int _productCount;
    private int _categoryCount;
    private int _brandCount;
    private int _installmentCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
    }

    private async Task LoadStats()
    {
        try
        {
            var products = await Api.GetProductsAsync();
            var categories = await Api.GetCategoriesAsync();
            var brands = await Api.GetBrandsAsync();
            var installments = await Api.GetInstallmentsAsync();

            _productCount = products.Count;
            _categoryCount = categories.Count;
            _brandCount = brands.Count;
            _installmentCount = installments.Count;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
