@page "/product-attributes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Product Attributes - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Product Attributes</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Product Attribute</button>
    </div>

    @if (_items == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_items.Count == 0)
    {
        <div class="alert alert-info">No product attributes found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ProductId</th>
                    <th>AttributeId</th>
                    <th>Value</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _items)
                {
                    <tr>
                        <td>@a.Id</td>
                        <td>@a.ProductId</td>
                        <td>@a.AttributeId</td>
                        <td>@a.Value</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditItem(a)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(a.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Product Attribute" : "Add Product Attribute")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingItem" OnValidSubmit="SaveItem">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>ProductId</label>
                            <InputNumber @bind-Value="_editingItem.ProductId" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>AttributeId</label>
                            <InputNumber @bind-Value="_editingItem.AttributeId" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Value</label>
                            <InputText @bind-Value="_editingItem.Value" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductAttribute>? _items;
    private bool _showModal;
    private bool _isEdit;
    private ProductAttribute _editingItem = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _items = await Api.GetProductAttributesAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingItem = new ProductAttribute();
        _showModal = true;
    }

    private void EditItem(ProductAttribute a)
    {
        _isEdit = true;
        _editingItem = new ProductAttribute
        {
            Id = a.Id,
            ProductId = a.ProductId,
            AttributeId = a.AttributeId,
            Value = a.Value
        };
        _showModal = true;
    }

    private async Task SaveItem()
    {
        bool success = _isEdit
            ? await Api.UpdateProductAttributeAsync(_editingItem)
            : await Api.CreateProductAttributeAsync(_editingItem);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteItem(int id)
    {
        if (await Api.DeleteProductAttributeAsync(id))
            await LoadData();
    }
}
