@page "/product-images"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminApiService Api

<PageTitle>Manage Product Images - Avrang Admin</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Product Images</h1>
        <button class="btn btn-success" @onclick="OpenAddModal">Add Product Image</button>
    </div>

    @if (_images == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_images.Count == 0)
    {
        <div class="alert alert-info">No images found.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ProductId</th>
                    <th>Image</th>
                    <th>Main</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in _images)
                {
                    <tr>
                        <td>@i.Id</td>
                        <td>@i.ProductId</td>
                        <td><img src="@i.ImageUrl" style="width:80px;height:40px;object-fit:cover;" /></td>
                        <td>@(i.IsMain ? "Yes" : "No")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditImage(i)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteImage(i.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Product Image" : "Add Product Image")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showModal = false"></button>
                </div>
                <EditForm Model="@_editingImage" OnValidSubmit="SaveImage">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label>ProductId</label>
                            <InputNumber @bind-Value="_editingImage.ProductId" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Image URL</label>
                            <InputText @bind-Value="_editingImage.ImageUrl" class="form-control" />
                        </div>
                        <div class="form-check">
                            <InputCheckbox @bind-Value="_editingImage.IsMain" class="form-check-input" id="imgMain" />
                            <label class="form-check-label" for="imgMain">Is Main</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductImage>? _images;
    private bool _showModal;
    private bool _isEdit;
    private ProductImage _editingImage = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _images = await Api.GetProductImagesAsync();
    }

    private void OpenAddModal()
    {
        _isEdit = false;
        _editingImage = new ProductImage();
        _showModal = true;
    }

    private void EditImage(ProductImage i)
    {
        _isEdit = true;
        _editingImage = new ProductImage
        {
            Id = i.Id,
            ProductId = i.ProductId,
            ImageUrl = i.ImageUrl,
            IsMain = i.IsMain
        };
        _showModal = true;
    }

    private async Task SaveImage()
    {
        bool success = _isEdit
            ? await Api.UpdateProductImageAsync(_editingImage)
            : await Api.CreateProductImageAsync(_editingImage);

        if (success)
        {
            _showModal = false;
            await LoadData();
        }
    }

    private async Task DeleteImage(int id)
    {
        if (await Api.DeleteProductImageAsync(id))
            await LoadData();
    }
}
